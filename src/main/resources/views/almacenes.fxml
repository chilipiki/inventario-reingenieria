<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/20"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../styles/styles.css">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- Header -->
    <VBox spacing="10">
        <Label text="Gestión de Almacenes" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212121;"/>
        <Label text="Administra los almacenes del inventario"
               wrapText="true"
               style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
    </VBox>

    <!-- Panel de filtros -->
    <VBox spacing="8" style="-fx-background-color: #ddeaf7; -fx-padding: 10; -fx-background-radius: 6;">
        <Label text="🔍 Filtros de búsqueda" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Nombre:"/>
                <TextField fx:id="filtroNombre" promptText="Buscar por nombre..." prefHeight="32"/>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Ubicación:"/>
                <TextField fx:id="filtroUbicacion" promptText="Buscar por ubicación..." prefHeight="32"/>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Último usuario:"/>
                <TextField fx:id="filtroUsuario" promptText="Buscar por usuario..." prefHeight="32"/>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Fecha creación (desde):"/>
                <DatePicker fx:id="filtroFechaDesde" prefWidth="150" prefHeight="32"/>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Fecha creación (hasta):"/>
                <DatePicker fx:id="filtroFechaHasta" prefWidth="150" prefHeight="32"/>
            </VBox>
            <VBox spacing="3" alignment="BOTTOM_LEFT">
                <Label text=" "/>
                <Button text="🧹 Limpiar" onAction="#handleLimpiarFiltros"
                        styleClass="button-secondary" prefHeight="32"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Tabla de almacenes -->
    <TableView fx:id="almacenesTable"
               VBox.vgrow="ALWAYS"
               style="-fx-font-size: 12px;">

        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nombreColumn" text="Nombre" prefWidth="150"/>
            <TableColumn fx:id="ubicacionColumn" text="Ubicación" prefWidth="180"/>
            <TableColumn fx:id="fechaCreacionColumn" text="Fecha Creación" prefWidth="145"/>
            <TableColumn fx:id="fechaModificacionColumn" text="Última Modificación" prefWidth="145"/>
            <TableColumn fx:id="ultimoUsuarioColumn" text="Último Usuario" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- Botones de acción -->
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="agregarBtn" text="➕ Agregar" styleClass="button-success"
                onAction="#handleAgregar" prefHeight="35"/>
        <Button fx:id="editarBtn" text="✏️ Editar" styleClass="button-primary"
                onAction="#handleEditar" prefHeight="35"/>
        <Button fx:id="eliminarBtn" text="🗑️ Eliminar" styleClass="button-danger"
                onAction="#handleEliminar" prefHeight="35"/>
        <Button fx:id="actualizarBtn" text="🔄 Actualizar" styleClass="button-secondary"
                onAction="#handleActualizar" prefHeight="35"/>
    </HBox>
</VBox>
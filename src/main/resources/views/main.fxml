<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../styles/styles.css,@../styles/navigation.css">

    <!-- TOPBAR: usuario + cerrar sesión -->
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="15"
              style="-fx-background-color: #015294; -fx-padding: 8 20 8 20;">
            <Label fx:id="userNameLabel" text="Usuario"
                   style="-fx-text-fill: white; -fx-font-size: 12px;"/>
            <Label fx:id="userRoleLabel" text="Rol"
                   style="-fx-text-fill: #f8bb00; -fx-font-size: 11px; -fx-font-weight: bold;"/>
            <Button text="Cerrar Sesión" onAction="#handleLogout"
                    styleClass="logout-button"/>
        </HBox>
    </top>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <StackPane fx:id="contentStackPane"
                   style="-fx-background-color: #f5f8fc;">

            <!-- ===================== VISTA: INICIO ===================== -->
            <VBox fx:id="homeView" alignment="CENTER" spacing="25">

                <!-- Logo -->
                <ImageView fx:id="logoImage" fitWidth="140" fitHeight="140"
                           preserveRatio="true">
                    <image><Image url="@../img/escudo_unison.png"/></image>
                </ImageView>

                <!-- Título y autor -->
                <VBox alignment="CENTER" spacing="6">
                    <Label text="Sistema de Inventario"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #015294;"/>
                    <Label text="Gestión de Calidad del Software II"
                           style="-fx-font-size: 13px; -fx-text-fill: #5a7fa0;"/>
                </VBox>

                <!-- Cards estadísticas -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="6" alignment="CENTER"
                          style="-fx-background-color: white; -fx-padding: 18 25; -fx-background-radius: 4; -fx-effect: dropshadow(gaussian, rgba(0,82,158,0.12), 6, 0, 0, 2); -fx-min-width: 140;">
                        <Label text="📦 Productos"
                               style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                        <Label fx:id="productosCountLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #00529e;"/>
                    </VBox>
                    <VBox spacing="6" alignment="CENTER"
                          style="-fx-background-color: white; -fx-padding: 18 25; -fx-background-radius: 4; -fx-effect: dropshadow(gaussian, rgba(0,82,158,0.12), 6, 0, 0, 2); -fx-min-width: 140;">
                        <Label text="🏢 Almacenes"
                               style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                        <Label fx:id="almacenesCountLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #00529e;"/>
                    </VBox>
                    <VBox spacing="6" alignment="CENTER"
                          style="-fx-background-color: white; -fx-padding: 18 25; -fx-background-radius: 4; -fx-effect: dropshadow(gaussian, rgba(0,82,158,0.12), 6, 0, 0, 2); -fx-min-width: 140;">
                        <Label text="📊 Stock Total"
                               style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                        <Label fx:id="stockTotalLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f8bb00;"/>
                    </VBox>
                </HBox>

                <!-- NavBar horizontal (como en el boceto) -->
                <HBox fx:id="navBar" alignment="CENTER" spacing="10"
                      style="-fx-background-color: white; -fx-padding: 12 25; -fx-background-radius: 4; -fx-effect: dropshadow(gaussian, rgba(0,82,158,0.1), 4, 0, 0, 2);">

                    <Button fx:id="inicioBtn" text="Inicio"
                            onAction="#handleHome"
                            styleClass="nav-tab-active"
                            prefWidth="120" prefHeight="36"/>

                    <Button fx:id="productosBtn" text="Productos"
                            onAction="#handleProductos"
                            styleClass="nav-tab-button"
                            prefWidth="120" prefHeight="36"
                            managed="false" visible="false"/>

                    <Button fx:id="almacenesBtn" text="Almacenes"
                            onAction="#handleAlmacenes"
                            styleClass="nav-tab-button"
                            prefWidth="120" prefHeight="36"
                            managed="false" visible="false"/>

                    <Button fx:id="configBtn" text="⚙ Config"
                            onAction="#handleConfig"
                            styleClass="nav-tab-button"
                            prefWidth="120" prefHeight="36"
                            managed="false" visible="false"/>
                </HBox>
            </VBox>

            <!-- ===================== VISTA: PRODUCTOS ===================== -->
            <BorderPane fx:id="productosView"
                        managed="false" visible="false">
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="15"
                          style="-fx-background-color: white; -fx-padding: 10 20; -fx-border-width: 0 0 1 0; -fx-border-color: #b3cde0;">
                        <Button text="❮  Volver" onAction="#handleHome"
                                style="-fx-background-color: transparent; -fx-text-fill: #00529e; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-width: 0;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Gestión de Productos"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #015294;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                </top>
                <center>
                    <VBox fx:id="productosContent"/>
                </center>
            </BorderPane>

            <!-- ===================== VISTA: ALMACENES ===================== -->
            <BorderPane fx:id="almacenesView"
                        managed="false" visible="false">
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="15"
                          style="-fx-background-color: white; -fx-padding: 10 20; -fx-border-width: 0 0 1 0; -fx-border-color: #b3cde0;">
                        <Button text="❮  Volver" onAction="#handleHome"
                                style="-fx-background-color: transparent; -fx-text-fill: #00529e; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-width: 0;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Gestión de Almacenes"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #015294;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                </top>
                <center>
                    <VBox fx:id="almacenesContent"/>
                </center>
            </BorderPane>

            <!-- ===================== VISTA: CONFIG ===================== -->
            <BorderPane fx:id="configView"
                        managed="false" visible="false">
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="15"
                          style="-fx-background-color: white; -fx-padding: 10 20; -fx-border-width: 0 0 1 0; -fx-border-color: #b3cde0;">
                        <Button text="❮  Volver" onAction="#handleHome"
                                style="-fx-background-color: transparent; -fx-text-fill: #00529e; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-width: 0;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Configuración"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #015294;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                </top>
                <center>
                    <VBox fx:id="configContent"/>
                </center>
            </BorderPane>

        </StackPane>
    </center>
</BorderPane>
